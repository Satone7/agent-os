{
  "name": "@anthropic/agent-os",
  "version": "1.0.0",
  "description": "Flow-driven multi-agent collaboration platform for Claude CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-os": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "claude",
    "agent",
    "orchestration",
    "multi-agent",
    "cli",
    "workflow"
  ],
  "author": "Anthropic",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "date-fns": "^3.6.0",
    "fast-glob": "^3.3.3",
    "inquirer": "^9.2.23",
    "js-yaml": "^4.1.0",
    "pino": "^8.20.0",
    "pino-pretty": "^11.2.2",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.10",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "flows",
    "prompts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropic/agent-os.git"
  },
  "bugs": {
    "url": "https://github.com/anthropic/agent-os/issues"
  },
  "homepage": "https://github.com/anthropic/agent-os#readme"
}
